{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "default_agent": "plan",
  "snapshot": false,
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
   "command": {
    "auto-plan": {
      "description": "Toggle auto-switch to plan mode after build",
      "template": "Toggle auto-plan mode"
    }
  },
  "agent": {
    "plan": {
      "model": "opencode-go/glm-5.2"
      // "model": "opencode-go/deepseek-v4-flash"
    },
    "build": {
      "model": "opencode-go/deepseek-v4-flash"
    }
  },
  "disabled_providers": [
    "opencodego2"
  ],
  "provider": {
    "opencodego2": {
      "name": "OpenCode Go #2",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://opencode.ai/zen/go/"
      },
      "models": {
        "glm-5.2": {
          "name": "GLM-5.2"
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash"
        }
      }
    }
  }
}
