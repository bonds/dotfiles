#!/usr/bin/env bash
# Pre-push hook — tracked in .githooks/pre-push (not .git/hooks/).
# Activated by core.hooksPath = ~/.githooks in git config.
# Runs nix flake check (format + secrets) before pushing.
# Bypass with: git push --no-verify
set -euo pipefail

cd "$HOME/.config/nix"
remote="$1"
url="$2"

echo "pre-push: running nix flake check (format + secrets) for nix config..."
if ! nix flake check --no-build 2>&1; then
  echo "pre-push: nix flake check FAILED — push aborted." >&2
  echo "  Fix errors above or bypass with 'git push --no-verify'." >&2
  exit 1
fi
echo "pre-push: checks passed."
