#!/bin/sh
# Update huggingface-hub to the latest release version in the nix overlay
# Usage: update-huggingface-hub [--dry-run] [--no-rebuild]

set -e

OVERLAY="$HOME/.config/nix/modules/huggingface-hub-overlay.nix"

echo "Fetching latest huggingface-hub release..."
VERSION=$(curl -sL https://api.github.com/repos/huggingface/huggingface_hub/releases/latest | jq -r '.tag_name' | sed 's/^v//')

if [ -z "$VERSION" ]; then
    echo "Error: could not determine latest huggingface-hub version" >&2
    exit 1
fi

echo "Latest version: $VERSION"

CURRENT_VERSION=$(grep 'version = ' "$OVERLAY" | head -1 | sed 's/.*"\(.*\)".*/\1/')
if [ "$VERSION" = "$CURRENT_VERSION" ]; then
    echo "Already up to date ($CURRENT_VERSION). Nothing to do."
    exit 0
fi

echo "Prefetching source tarball..."
BASE32_HASH=$(nix-prefetch-url --type sha256 "https://github.com/huggingface/huggingface_hub/archive/v${VERSION}.tar.gz" 2>/dev/null)
SRI_HASH=$(nix hash to-sri --type sha256 "$BASE32_HASH" 2>/dev/null)

echo "Hash: $SRI_HASH"

if [ "$1" = "--dry-run" ]; then
    echo "Dry run: would update overlay to version $VERSION with hash $SRI_HASH"
    exit 0
fi

if [ "$1" = "--no-rebuild" ]; then
    NO_REBUILD=1
fi

# Update the overlay file using sed
sed -i.bak \
    -e "s/version = \"[^\"]*\";/version = \"$VERSION\";/" \
    -e "s|hash = \"sha256-[^\"]*\";|hash = \"$SRI_HASH\";|" \
    "$OVERLAY"

rm -f "$OVERLAY.bak"

echo "Formatting overlay..."
alejandra "$OVERLAY"

if [ -n "$NO_REBUILD" ]; then
    echo "Done. huggingface-hub overlay updated to $VERSION (skipped rebuild)."
else
    echo "Rebuilding..."
    cd "$HOME/.config/nix"
    nr
    echo "Done. huggingface-hub updated to $VERSION."
fi
