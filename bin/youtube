#!/bin/sh

usage="Usage: youtube [-adp] <search terms>"

args=`getopt adp $* 2>/dev/null`

if [ $? -ne 0 ]; then
    echo "$usage"
    exit 2
fi

set -- $args
while [ $# -ne 0 ]; do
case "$1"
in
    -a)
        audio="yes"; shift;;
    -d)
        download="yes"; shift;;
    -p)
        polyptych="yes"; shift;;
    --)
        shift; break;;
esac
done

if [ -z "$*" ]; then
    echo "$usage"
    exit 3
fi

if [ "${download:-}" = yes ]; then
    if [ "${audio:-}" = yes ]; then
        yt-dlp --format bestaudio --default-search ytsearch "$*"
    else
        while ! yt-dlp --default-search ytsearch --external-downloader aria2c --external-downloader-args '-c -j 3 -x 3 -s 3 -k 1M' "$*"
        do
            sleep 60
        done
    fi
elif [ "${polyptych:-}" = yes ]; then
    ~/Documents/undated/repos/polyptych/polyptych.app/Contents/MacOS/polyptych ytdl://"$*"
else
    if [ "${audio:-}" = yes ]; then
        mpv --fs --ytdl-raw-options=default-search=ytsearch,format=bestaudio ytdl://"$*"
    else
        mpv --fs --really-quiet --cache=yes --demuxer-max-bytes=200M --demuxer-readahead-secs=60 --ytdl-raw-options="default-search=ytsearch,format=bestvideo[height<=?1080]+bestaudio/best" ytdl://"$*"
    fi
fi
