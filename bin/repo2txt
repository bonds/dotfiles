#!/usr/bin/env fish

if not set gitroot (git rev-parse --show-toplevel)
    echo "not a git repo"
    exit 1
end
set shortname (string lower (basename $gitroot))

set pwd (pwd)
if not test "$gitroot" = "$pwd"
    echo "warning: not at git root, output may be misleading" >&2
end

set output "$pwd/../$shortname.txt"
echo "" >"$output"

echo "\$ cd $pwd" >>$output
echo >>$output

echo "\$ git remote -v" >>$output
git remote -v >>$output
echo >>$output

echo "\$ git ls-files" >>$output
echo >>$output
git ls-files >>$output
echo >>$output

for file in (git ls-files | grep -iE '\.(md|py|txt|html|nix|toml|fish|conf|xml|json)$')
    echo "\$ cat $file" >>$output
    echo >>$output
    cat "$file" >>$output
    echo >>$output
end
